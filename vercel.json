{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "framework": null,
  "rewrites": [
    {
      "source": "/counter/:path*",
      "destination": "/counter/index.html"
    },
    {
      "source": "/notes/:path*",
      "destination": "/notes/index.html"
    },
    {
      "source": "/things/:path*",
      "destination": "/things/index.html"
    }
  ]
}
